{
	"name": "repo-report",
	"version": "0.4.0",
	"description": "CLI to list all repos a user has access to, and report on their configuration in aggregate.",
	"bin": "./bin/run.mjs",
	"main": false,
	"sideEffects": false,
	"exports": {
		"./package.json": "./package.json"
	},
	"scripts": {
		"prepack": "npmignore --auto --commentLines=autogenerated",
		"prepublishOnly": "safe-publish-latest",
		"prepublish": "not-in-publish || npm run prepublishOnly",
		"test": "npm run tests-only",
		"tests-only": "nyc tape \"test/**/*.js\" | tap-spec",
		"lint": "eslint .",
		"postlint": "tsc && attw -P",
		"pretest": "npm run lint",
		"posttest": "npx npm@\">= 10.2\" audit --production",
		"version": "auto-changelog && git add CHANGELOG.md",
		"postversion": "auto-changelog && git add CHANGELOG.md && git commit --no-edit --amend && git tag -f \"v$(node -e \"console.log(require('./package.json').version)\")\""
	},
	"repository": "https://github.com/ljharb/repo-report",
	"author": "Jordan Harband <ljharb@gmail.com>",
	"funding": {
		"url": "https://github.com/sponsors/ljharb"
	},
	"license": "MIT",
	"dependencies": {
		"@octokit/graphql": "^9.0.3",
		"cli-table": "^0.3.11",
		"jsonschema": "^1.5.0",
		"minimatch": "^10.2.5",
		"pargs": "^1.4.2"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@ljharb/eslint-config": "^22.2.3",
		"@ljharb/tsconfig": "^0.3.2",
		"@types/cli-table": "^0.3.4",
		"@types/node": "^22.19.17",
		"@types/tape": "^5.8.1",
		"auto-changelog": "^2.6.0",
		"eslint": "^10.5.0",
		"fetch-mock": "^12.6.0",
		"in-publish": "^2.0.1",
		"mock-property": "^1.1.2",
		"npmignore": "^0.3.5",
		"nyc": "^18.0.0",
		"safe-publish-latest": "^2.0.0",
		"tap-spec": "^5.0.0",
		"tape": "^5.10.2",
		"typescript": "next"
	},
	"engines": {
		"node": "^22.21 || ^24.12 || >= 25.2.1"
	},
	"auto-changelog": {
		"output": "CHANGELOG.md",
		"template": "keepachangelog",
		"unreleased": false,
		"commitLimit": false,
		"backfillLimit": false,
		"hideCredit": true
	},
	"publishConfig": {
		"ignore": [
			".github/workflows",
			"Repo-Report Table.png",
			"test/"
		]
	}
}
